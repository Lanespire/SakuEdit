# ── AI / LLM ──
OPENROUTER_API_KEY=your_openrouter_api_key_here  # OpenRouter APIキー（AI字幕生成・サムネイル・構成チャット）

# ── Database (Turso) ──
TURSO_DATABASE_URL="libsql://your-database.turso.io"  # Turso データベースURL
TURSO_AUTH_TOKEN="your_turso_auth_token_here"  # Turso 認証トークン
TURSO_DATABASE_NAME="your-database"  # Turso データベース名（migration適用時に使用）
DATABASE_URL="file:./dev.db"  # Prisma CLI用ローカルSQLiteパス

# ── Auth (Better Auth) ──
BETTER_AUTH_SECRET="sakuedit-secret-key-change-in-production"  # 認証シークレットキー ※本番では必ず変更してください
BETTER_AUTH_URL="http://localhost:3000"  # サーバーサイド認証ベースURL
NEXT_PUBLIC_BETTER_AUTH_URL=  # クライアントサイド認証ベースURL（未設定時はデフォルト）

# ── Stripe（決済） ──
STRIPE_SECRET_KEY=sk_test_xxx  # Stripe シークレットキー
STRIPE_PUBLISHABLE_KEY=pk_test_xxx  # Stripe 公開キー（サーバーサイドフォールバック）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx  # Stripe 公開キー（クライアントサイド）
STRIPE_WEBHOOK_SECRET=whsec_xxx  # Stripe Webhook シークレット
STRIPE_WEBHOOK_URL=  # Stripe Webhook URL（SST デプロイ時に使用）

# ── Whisper（音声認識） ──
WHISPER_CPP_VERSION=1.7.4  # whisper.cpp のバージョン
WHISPER_MODEL=base  # Whisper モデル名（tiny, base, small, medium, large）
WHISPER_ROOT=  # whisper.cpp のルートディレクトリ（カスタムパス指定時）
WHISPER_MODEL_PATH=  # Whisper モデルファイルの直接パス
WHISPER_MODEL_DIR=  # Whisper モデルディレクトリ
WHISPER_EXECUTABLE_PATH=  # whisper 実行ファイルのパス

# ── 動画処理バイナリ ──
PROCESSING_RUNTIME_ROOT=  # 動画処理ランタイムのルートディレクトリ
FFMPEG_BIN=  # ffmpeg バイナリのパス
FFPROBE_BIN_PATH=  # ffprobe バイナリのパス
YT_DLP_BIN=  # yt-dlp バイナリのパス
REMOTION_CLI_PATH=  # Remotion CLI のパス

# ── 動画ストレージ (S3) ──
VIDEO_BUCKET_NAME=  # S3 バケット名（開発時は SST outputs から自動取得）
VIDEO_BUCKET_REGION=  # S3 バケットリージョン（開発時は ap-northeast-1）
AWS_REGION=  # AWS リージョン（VIDEO_BUCKET_REGION のフォールバック）

# ── 動画処理ワーカー ──
PROCESSING_WORKER_TOKEN=  # 動画処理ワーカー認証トークン
VIDEO_PROCESSOR_LAYER_ARNS=  # Lambda レイヤー ARN（カンマ区切り、SST デプロイ時）

# ── AWS / Remotion Lambda レンダリング ──
AWS_ACCESS_KEY_ID=  # AWS アクセスキーID（Remotion Lambda レンダリング用）
AWS_SECRET_ACCESS_KEY=  # AWS シークレットアクセスキー
REMOTION_AWS_ACCESS_KEY_ID=  # Remotion 専用 AWS アクセスキーID（AWS_ACCESS_KEY_ID のフォールバック）
REMOTION_AWS_SECRET_ACCESS_KEY=  # Remotion 専用 AWS シークレットアクセスキー

# ── 外部サービス API ──
ELEVENLABS_API_KEY=  # ElevenLabs API キー（テキスト読み上げ）
BEATOVEN_API_KEY=  # Beatoven API キー（BGM生成）
NEXT_PUBLIC_PEXELS_API_KEY=your_pexels_api_key_here  # Pexels API キー（ストック動画・画像検索）

# ── PostHog（アナリティクス） ──
NEXT_PUBLIC_POSTHOG_ENABLED=false  # PostHog を有効にするか（true/false）
NEXT_PUBLIC_POSTHOG_KEY=  # PostHog プロジェクトAPIキー
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com  # PostHog ホスト

# ── Sentry（エラー監視） ──
NEXT_PUBLIC_SENTRY_ENABLED=false  # Sentry を有効にするか（true/false）
NEXT_PUBLIC_SENTRY_DSN=  # Sentry DSN（クライアントサイド）
SENTRY_DSN=  # Sentry DSN（サーバーサイド / Edge）
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1  # トレースサンプリングレート（0〜1）
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1  # セッションリプレイサンプリングレート
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0  # エラー時リプレイサンプリングレート
NEXT_PUBLIC_SENTRY_DEBUG=false  # Sentry デバッグモード
SENTRY_TRACES_SAMPLE_RATE=1  # サーバーサイドトレースサンプリングレート
SENTRY_DEBUG=false  # サーバーサイド Sentry デバッグモード

# ── アプリ設定 ──
NEXT_PUBLIC_APP_URL=http://localhost:3000  # アプリの公開URL（metadataBase, sitemap等）
NEXT_PUBLIC_RENDERING_ENABLED=false  # クラウドレンダリング機能の有効化（true/false）
NEXT_PUBLIC_DISABLE_PROJECT_LOADING=false  # プロジェクト読み込みを無効化（開発用、true/false）

# ── Prisma CLI note ──
# Prisma schema は sqlite provider のため、CLI は DATABASE_URL(file:) を参照します。
# アプリ runtime は TURSO_DATABASE_URL / TURSO_AUTH_TOKEN 経由で Turso を使います。
# migration 適用時は `turso db shell "$TURSO_DATABASE_NAME" < prisma/migrations/.../migration.sql` を使います。
