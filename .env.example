# AI / ASR
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-3

# Database (Neon PostgreSQL)
# For local development with SQLite:
DATABASE_URL="file:./dev.db"
# For Neon (production):
# DATABASE_URL="postgresql://[user]:[password]@[endpoint].neon.tech/[database]?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://[user]:[password]@[endpoint].neon.tech/[database]?sslmode=require"

# Auth
BETTER_AUTH_SECRET="sakuedit-secret-key-change-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Storage
UPLOAD_DIR="./uploads"

# SST Secrets (set via `sst secrets set`)
# These are set in SST, not in .env:
# - DatabaseUrl / DatabaseUrlDev
# - NextAuthSecret / NextAuthSecretDev
# - OpenRouterApiKey / OpenRouterApiKeyDev
# - DeepgramApiKey / DeepgramApiKeyDev
