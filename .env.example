# AI / ASR
OPENROUTER_API_KEY=your_openrouter_api_key_here
WHISPER_CPP_VERSION=1.7.4
WHISPER_MODEL=base

# Database
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your_turso_auth_token_here"
TURSO_DATABASE_NAME="your-database"
DATABASE_URL="file:./dev.db"

# Auth
BETTER_AUTH_SECRET="sakuedit-secret-key-change-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Prisma CLI note
# Prisma schema は sqlite provider のため、CLI は DATABASE_URL(file:) を参照します。
# アプリ runtime は TURSO_DATABASE_URL / TURSO_AUTH_TOKEN 経由で Turso を使います。
# migration 適用時は `turso db shell "$TURSO_DATABASE_NAME" < prisma/migrations/.../migration.sql` を使います。
