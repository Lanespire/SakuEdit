# AI / ASR
AI_API_KEY=your_zai_api_key_here
AI_ENDPOINT=https://api.z.ai/api/coding/paas/v4
GROQ_API_KEY=your_groq_api_key_here  # Required for Whisper ASR

# OpenRouter (optional - for additional models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database (Neon PostgreSQL)
# For local development with SQLite:
DATABASE_URL="file:./dev.db"
# For Neon (production):
# DATABASE_URL="postgresql://[user]:[password]@[endpoint].neon.tech/[database]?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://[user]:[password]@[endpoint].neon.tech/[database]?sslmode=require"

# Auth
BETTER_AUTH_SECRET="sakuedit-secret-key-change-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Storage
UPLOAD_DIR="./uploads"

# SST Secrets (set via `sst secrets set`)
# These are set in SST, not in .env:
# - DatabaseUrl / DatabaseUrlDev
# - NextAuthSecret / NextAuthSecretDev
# - GroqApiKey / GroqApiKeyDev
